{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://jumi.local/schemas/theme_settings.schema.json",
  "title": "Theme Settings Knowledge Base",
  "type": "object",
  "required": ["schemaVersion", "description", "data"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "description": { "$ref": "#/$defs/themeDescription" },
    "data": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/themeItem" }
    }
  },
  "$defs": {
    "hslString": {
      "type": "string",
      "pattern": "^\\d+(?:\\.\\d+)?\\s+\\d+(?:\\.\\d+)?%\\s+\\d+(?:\\.\\d+)?%$"
    },
    "rangeTuple": {
      "type": "array",
      "items": [{ "type": "number" }, { "type": "number" }],
      "minItems": 2,
      "maxItems": 2
    },
    "variationRange": {
      "type": "object",
      "required": ["hue", "saturation", "lightness"],
      "additionalProperties": false,
      "properties": {
        "hue": { "$ref": "#/$defs/rangeTuple" },
        "saturation": { "$ref": "#/$defs/rangeTuple" },
        "lightness": { "$ref": "#/$defs/rangeTuple" }
      }
    },
    "textColors": {
      "type": "object",
      "required": ["base", "muted", "faint", "accent"],
      "additionalProperties": false,
      "properties": {
        "base": { "$ref": "#/$defs/hslString" },
        "muted": { "$ref": "#/$defs/hslString" },
        "faint": { "$ref": "#/$defs/hslString" },
        "accent": { "$ref": "#/$defs/hslString" }
      }
    },
    "textColorVariations": {
      "type": "object",
      "required": ["base", "muted", "faint", "accent"],
      "additionalProperties": false,
      "properties": {
        "base": { "$ref": "#/$defs/variationRange" },
        "muted": { "$ref": "#/$defs/variationRange" },
        "faint": { "$ref": "#/$defs/variationRange" },
        "accent": { "$ref": "#/$defs/variationRange" }
      }
    },
    "colorPalette": {
      "type": "object",
      "required": ["background", "textColors", "primary", "secondary"],
      "additionalProperties": false,
      "properties": {
        "background": { "$ref": "#/$defs/hslString" },
        "textColors": { "$ref": "#/$defs/textColors" },
        "primary": { "$ref": "#/$defs/hslString" },
        "secondary": { "$ref": "#/$defs/hslString" }
      }
    },
    "colorVariations": {
      "type": "object",
      "required": ["background", "textColors", "primary", "secondary"],
      "additionalProperties": false,
      "properties": {
        "background": { "$ref": "#/$defs/variationRange" },
        "textColors": { "$ref": "#/$defs/textColorVariations" },
        "primary": { "$ref": "#/$defs/variationRange" },
        "secondary": { "$ref": "#/$defs/variationRange" }
      }
    },
    "sizeRecommendations": {
      "type": "object",
      "required": ["heading", "subheading"],
      "additionalProperties": false,
      "properties": {
        "heading": { "type": "string", "minLength": 1 },
        "subheading": { "type": "string", "minLength": 1 }
      }
    },
    "themeItem": {
      "type": "object",
      "required": [
        "pairType",
        "fontHeading",
        "fontBody",
        "sectors",
        "tone",
        "audienceType",
        "colorPalette",
        "colorVariations",
        "rationale",
        "sizeRecommendations",
        "iconLibrary"
      ],
      "additionalProperties": false,
      "properties": {
        "pairType": { "type": "string", "minLength": 1 },
        "fontHeading": { "type": "string", "minLength": 1 },
        "fontBody": { "type": "string", "minLength": 1 },
        "sectors": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "tone": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "audienceType": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "colorPalette": { "$ref": "#/$defs/colorPalette" },
        "colorVariations": { "$ref": "#/$defs/colorVariations" },
        "rationale": { "type": "string", "minLength": 1 },
        "sizeRecommendations": { "$ref": "#/$defs/sizeRecommendations" },
        "iconLibrary": {
          "type": "string",
          "enum": ["lucide", "phosphor"]
        }
      }
    },
    "themeDescription": {
      "type": "object",
      "required": [
        "pairType",
        "fontHeading",
        "fontBody",
        "sectors",
        "tone",
        "audienceType",
        "colorPalette",
        "colorVariations",
        "rationale",
        "sizeRecommendations",
        "iconLibrary"
      ],
      "additionalProperties": false,
      "properties": {
        "pairType": { "type": "string" },
        "fontHeading": { "type": "string" },
        "fontBody": { "type": "string" },
        "sectors": { "type": "string" },
        "tone": { "type": "string" },
        "audienceType": { "type": "string" },
        "colorPalette": {
          "type": "object",
          "required": ["background", "textColors", "primary", "secondary"],
          "additionalProperties": false,
          "properties": {
            "background": { "type": "string" },
            "textColors": {
              "type": "object",
              "required": ["base", "muted", "faint", "accent"],
              "additionalProperties": false,
              "properties": {
                "base": { "type": "string" },
                "muted": { "type": "string" },
                "faint": { "type": "string" },
                "accent": { "type": "string" }
              }
            },
            "primary": { "type": "string" },
            "secondary": { "type": "string" }
          }
        },
        "colorVariations": {
          "type": "object",
          "required": ["background", "textColors", "primary", "secondary"],
          "additionalProperties": false,
          "properties": {
            "background": {
              "type": "object",
              "required": ["hue", "saturation", "lightness"],
              "additionalProperties": false,
              "properties": {
                "hue": { "type": "string" },
                "saturation": { "type": "string" },
                "lightness": { "type": "string" }
              }
            },
            "textColors": {
              "type": "object",
              "required": ["base", "muted", "faint", "accent"],
              "additionalProperties": false,
              "properties": {
                "base": {
                  "type": "object",
                  "required": ["hue", "saturation", "lightness"],
                  "additionalProperties": false,
                  "properties": {
                    "hue": { "type": "string" },
                    "saturation": { "type": "string" },
                    "lightness": { "type": "string" }
                  }
                },
                "muted": {
                  "type": "object",
                  "required": ["hue", "saturation", "lightness"],
                  "additionalProperties": false,
                  "properties": {
                    "hue": { "type": "string" },
                    "saturation": { "type": "string" },
                    "lightness": { "type": "string" }
                  }
                },
                "faint": {
                  "type": "object",
                  "required": ["hue", "saturation", "lightness"],
                  "additionalProperties": false,
                  "properties": {
                    "hue": { "type": "string" },
                    "saturation": { "type": "string" },
                    "lightness": { "type": "string" }
                  }
                },
                "accent": {
                  "type": "object",
                  "required": ["hue", "saturation", "lightness"],
                  "additionalProperties": false,
                  "properties": {
                    "hue": { "type": "string" },
                    "saturation": { "type": "string" },
                    "lightness": { "type": "string" }
                  }
                }
              }
            },
            "primary": {
              "type": "object",
              "required": ["hue", "saturation", "lightness"],
              "additionalProperties": false,
              "properties": {
                "hue": { "type": "string" },
                "saturation": { "type": "string" },
                "lightness": { "type": "string" }
              }
            },
            "secondary": {
              "type": "object",
              "required": ["hue", "saturation", "lightness"],
              "additionalProperties": false,
              "properties": {
                "hue": { "type": "string" },
                "saturation": { "type": "string" },
                "lightness": { "type": "string" }
              }
            }
          }
        },
        "rationale": { "type": "string" },
        "sizeRecommendations": {
          "type": "object",
          "required": ["heading", "subheading"],
          "additionalProperties": false,
          "properties": {
            "heading": { "type": "string" },
            "subheading": { "type": "string" }
          }
        },
        "iconLibrary": { "type": "string" }
      }
    }
  }
}
