{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://jumi.local/schemas/theme_settings.schema.json",
  "title": "Theme Settings Knowledge Base",
  "type": "object",
  "required": [
    "schemaVersion",
    "description",
    "data"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "description": {
      "$ref": "#/$defs/themeDescription"
    },
    "data": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/themeItem"
      }
    }
  },
  "$defs": {
    "hslString": {
      "type": "string",
      "pattern": "^\\d+(?:\\.\\d+)?\\s+\\d+(?:\\.\\d+)?%\\s+\\d+(?:\\.\\d+)?%$"
    },
    "rangeTuple": {
      "type": "array",
      "items": [
        {
          "type": "number"
        },
        {
          "type": "number"
        }
      ],
      "minItems": 2,
      "maxItems": 2
    },
    "variationRange": {
      "type": "object",
      "required": [
        "hue",
        "saturation",
        "lightness"
      ],
      "additionalProperties": false,
      "properties": {
        "hue": {
          "$ref": "#/$defs/rangeTuple"
        },
        "saturation": {
          "$ref": "#/$defs/rangeTuple"
        },
        "lightness": {
          "$ref": "#/$defs/rangeTuple"
        }
      }
    },
    "textColors": {
      "type": "object",
      "required": [
        "base",
        "muted",
        "faint",
        "accent"
      ],
      "additionalProperties": false,
      "properties": {
        "base": {
          "$ref": "#/$defs/hslString"
        },
        "muted": {
          "$ref": "#/$defs/hslString"
        },
        "faint": {
          "$ref": "#/$defs/hslString"
        },
        "accent": {
