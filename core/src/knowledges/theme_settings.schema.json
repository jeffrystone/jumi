{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://jumi.local/schemas/theme_settings.schema.json",
  "title": "Theme Settings Knowledge Base",
  "type": "object",
  "required": ["schemaVersion", "description", "data"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "description": { "$ref": "#/$defs/themeDescription" },
    "data": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/themeItem" }
    }
  },
  "$defs": {
    "hslString": {
      "type": "string",
      "pattern": "^\\d+(?:\\.\\d+)?\\s+\\d+(?:\\.\\d+)?%\\s+\\d+(?:\\.\\d+)?%$"
    },
    "textColors": {
      "type": "object",
      "required": ["base", "muted", "faint", "accent"],
      "additionalProperties": false,
      "properties": {
        "base": { "$ref": "#/$defs/hslString" },
        "muted": { "$ref": "#/$defs/hslString" },
        "faint": { "$ref": "#/$defs/hslString" },
        "accent": { "$ref": "#/$defs/hslString" }
      }
    },
    "colorPalette": {
      "type": "object",
      "required": [
        "background",
        "textColors",
        "primary",
        "primaryHover",
        "primaryDisabled",
        "secondary",
        "secondaryHover",
        "secondaryDisabled"
      ],
      "additionalProperties": false,
      "properties": {
        "background": { "$ref": "#/$defs/hslString" },
        "textColors": { "$ref": "#/$defs/textColors" },
        "primary": { "$ref": "#/$defs/hslString" },
        "secondary": { "$ref": "#/$defs/hslString" },
        "primaryHover": { "$ref": "#/$defs/hslString" },
        "primaryDisabled": { "$ref": "#/$defs/hslString" },
        "secondaryHover": { "$ref": "#/$defs/hslString" },
        "secondaryDisabled": { "$ref": "#/$defs/hslString" }
      }
    },
    "sizeTier": {
      "type": "string",
      "enum": ["display", "hero", "section", "standard"],
      "description": "Масштаб типографики: display (крупные hero), hero, section, standard"
    },
    "accentWeight": {
      "type": "string",
      "enum": ["400", "500", "600", "700"]
    },
    "themeItem": {
      "type": "object",
      "required": [
        "pairType",
        "fontHeading",
        "fontBody",
        "accentWeight",
        "sectors",
        "tone",
        "audienceType",
        "colorPalette",
        "gradients",
        "link",
        "rationale",
        "sizeTier",
        "iconLibrary"
      ],
      "additionalProperties": false,
      "properties": {
        "pairType": { "type": "string", "minLength": 1 },
        "fontHeading": { "type": "string", "minLength": 1 },
        "fontBody": { "type": "string", "minLength": 1 },
        "accentWeight": { "$ref": "#/$defs/accentWeight" },
        "sectors": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "tone": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "audienceType": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["B2B", "B2C", "массмаркет"]
          }
        },
        "colorPalette": { "$ref": "#/$defs/colorPalette" },
        "rationale": { "type": "string", "minLength": 1 },
        "sizeTier": { "$ref": "#/$defs/sizeTier" },
        "iconLibrary": { "type": "string", "enum": ["lucide", "phosphor"] },
        "gradients": { "$ref": "#/$defs/gradients" },
        "link": { "$ref": "#/$defs/linkColors" }
      }
    },
    "themeDescription": {
      "type": "object",
      "required": [
        "pairType",
        "fontHeading",
        "fontBody",
        "accentWeight",
        "sectors",
        "tone",
        "audienceType",
        "colorPalette",
        "gradients",
        "link",
        "rationale",
        "sizeTier",
        "iconLibrary"
      ],
      "additionalProperties": false,
      "properties": {
        "pairType": { "type": "string" },
        "fontHeading": { "type": "string" },
        "fontBody": { "type": "string" },
        "accentWeight": { "type": "string" },
        "sectors": { "type": "string" },
        "tone": { "type": "string" },
        "audienceType": { "type": "string" },
        "colorPalette": { "type": "object", "additionalProperties": true },
        "rationale": { "type": "string" },
        "sizeTier": {
          "type": "string",
          "description": "Один из: display | hero | section | standard — градация размеров заголовка/подзаголовка"
        },
        "iconLibrary": { "type": "string" },
        "gradients": { "type": "object", "additionalProperties": true },
        "link": { "type": "object", "additionalProperties": true }
      }
    },
    "linkColors": {
      "type": "object",
      "required": ["color", "hover", "visited"],
      "additionalProperties": false,
      "properties": {
        "color": { "$ref": "#/$defs/hslString" },
        "hover": { "$ref": "#/$defs/hslString" },
        "visited": { "$ref": "#/$defs/hslString" }
      }
    },
    "gradients": {
      "type": "object",
      "required": ["background", "primary", "secondary", "text"],
      "additionalProperties": false,
      "properties": {
        "background": { "type": "string", "minLength": 1 },
        "primary": { "type": "string", "minLength": 1 },
        "secondary": { "type": "string", "minLength": 1 },
        "text": { "type": "string", "minLength": 1 }
      }
    }
  }
}
